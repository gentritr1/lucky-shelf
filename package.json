{
  "name": "lucky-shelf",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "fixtures:validate": "node --import tsx scripts/validate-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "fuzz": "node --import tsx scripts/fuzz.ts",
    "m0": "pnpm typecheck && pnpm fixtures:validate && pnpm test",
    "m1": "pnpm typecheck && pnpm fixtures:validate && pnpm test && pnpm fuzz -- --runs 50"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.1.1",
    "@shopify/react-native-skia": "2.6.9",
    "expo": "~57.0.2",
    "expo-audio": "57.0.0",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "57.0.0",
    "expo-router": "~57.0.3",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "~19.2.2",
    "tsx": "4.23.0",
    "typescript": "~6.0.3",
    "vitest": "4.1.9"
  }
}
