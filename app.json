{
  "expo": {
    "name": "Lucky Shelf",
    "slug": "lucky-shelf",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "luckyshelf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.gentlegen.luckyshelf",
      "supportsTablet": false
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
