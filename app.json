{
  "expo": {
    "name": "Lucky Shelf",
    "slug": "lucky-shelf",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "luckyshelf",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/branding/app-icon.png",
    "splash": {
      "image": "./assets/branding/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4E8D3"
    },
    "ios": {
      "bundleIdentifier": "com.gentlegen.luckyshelf",
      "supportsTablet": false
    },
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/branding/app-icon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
